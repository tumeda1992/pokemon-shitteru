{
  "name": "pokemon-shitteru",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema=./src/backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./src/backend/prisma/schema.prisma",
    "prisma:migrate:test": "DATABASE_URL='mysql://root:password@test-db:3306/pokemon_quiz' prisma migrate dev --schema=./src/backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./src/backend/prisma/schema.prisma",
    "test": "NODE_ENV=test DATABASE_URL='mysql://root:password@test-db:3306/pokemon_quiz' vitest run",
    "test:watch": "NODE_ENV=test DATABASE_URL='mysql://root:password@test-db:3306/pokemon_quiz' vitest watch",
    "test:coverage": "NODE_ENV=test DATABASE_URL='mysql://root:password@test-db:3306/pokemon_quiz' vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "fastify": "^5.2.1",
    "mysql2": "^3.14.0",
    "nanoid": "^5.1.5",
    "next": "15.2.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.25.9",
    "@eslint/eslintrc": "^3",
    "@prisma/client": "^6.5.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "20.17.25",
    "@types/react": "19.0.12",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^26.0.0",
    "prisma": "^6.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "typescript": "5.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.9"
  }
}
